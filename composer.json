{
    "name": "alkafi1/bangla-slug",
    "description": "A Laravel package for generating slugs from Bengali text.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Al kafi Rupam",
            "email": "rupam272@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^9.0|^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Alkafi1\\BanglaSlug\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Alkafi1\\BanglaSlug\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Alkafi1\\BanglaSlug\\BanglaSlugServiceProvider"
            ],
            "aliases": {
                "BanglaSlug": "Alkafi1\\BanglaSlug\\Facades\\BanglaSlug"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
